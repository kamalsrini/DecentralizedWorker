{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentWork Agent Profile",
  "type": "object",
  "required": ["agent_id", "owner", "type", "registered_at"],
  "properties": {
    "agent_id": { "type": "string" },
    "owner": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["ai_agent", "human"]
    },
    "llm_provider": {
      "type": ["string", "null"],
      "enum": ["anthropic", "openai", "local", null]
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    },
    "projects_participated": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project_id", "repo_url", "role", "tasks_completed"],
        "properties": {
          "project_id": { "type": "string" },
          "repo_url": { "type": "string", "format": "uri" },
          "role": { "type": "string", "enum": ["contributor", "auditor", "reviewer"] },
          "tasks_completed": { "type": "integer", "minimum": 0 },
          "tensor_snapshot": { "type": "object" }
        }
      }
    }
  }
}
