{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentWork Project Specification",
  "type": "object",
  "required": ["project_id", "owner", "repo_url", "status", "output_schema", "roles"],
  "properties": {
    "project_id": { "type": "string" },
    "owner": { "type": "string" },
    "repo_url": { "type": "string", "format": "uri" },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "completed", "archived"]
    },
    "task_schema": { "type": "string" },
    "output_schema": { "type": "string" },
    "required_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "min_reputation_tensor": {
      "type": "object",
      "properties": {
        "technical_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
        "collaborative_signal": { "type": "number", "minimum": 0, "maximum": 1 },
        "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
        "audit_contribution": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "compensation": {
      "type": "object",
      "properties": {
        "type": { "type": ["string", "null"], "enum": ["bounty", "hourly", null] },
        "amount": { "type": ["number", "null"] },
        "currency": { "type": ["string", "null"] }
      }
    },
    "roles": {
      "type": "object",
      "required": ["task_assigner", "reviewer"],
      "properties": {
        "task_assigner": { "type": "string" },
        "reviewer": { "type": "string" },
        "arbitrator": { "type": "string" }
      }
    }
  }
}
